# Copy this file to .env and fill in the values before running locally.
# Never commit .env to version control.

# A long random string used to sign session cookies.
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# Credentials for the first admin account created on a fresh database.
INITIAL_ADMIN_USER=admin
INITIAL_ADMIN_PASSWORD=change-me-to-a-strong-password

# Optional: path to the SQLite database file (default: evg.db)
# DATABASE_PATH=evg.db

# Set to 1 to enable Flask auto-reload in development (never use in production)
# FLASK_DEBUG=0
